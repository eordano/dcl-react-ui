{
  "name": "dcl-react-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "React (react-dom only) re-implementation of the Decentraland client UI, aiming for near-pixel-perfect parity. Vite SPA.",
  "scripts": {
    "dev": "vite --config vite.app.config.js",
    "build:app": "vite build --config vite.app.config.js",
    "build:overlay": "vite build --config vite.overlay.config.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.1.1",
    "three": "^0.185.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@storybook/addon-links": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@vitejs/plugin-react": "^6.0.3",
    "storybook": "^10.4.6",
    "vite": "^8.1.0"
  }
}
